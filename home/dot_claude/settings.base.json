{
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Skill",
      "MultiEdit",
      "WebSearch",
      "WebFetch",
      "mcp__pencil",
      "mcp__mlflow-mcp__*",
      "mcp__plugin_sentry_sentry__*"
    ],
    "deny": [
      "Read(.env*)",
      "Bash(terraform:*)",
      "Bash(git push origin main)",
      "Bash(printenv)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(git commit --amend)",
      "Bash(git commit --amend *)",
      "Bash(git rebase)",
      "Bash(git rebase *)"
    ]
  },
  "model": "opus",
  "enabledMcpjsonServers": [],
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "mcpServers": {},
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "branch=$(git -C \"$CLAUDE_WORKING_DIRECTORY\" rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'N/A'); osascript -e \"display notification \\\"Notification. [$branch]\\\" with title \\\"Claude Code\\\" sound name \\\"Funk\\\"\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "branch=$(git -C \"$CLAUDE_WORKING_DIRECTORY\" rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'N/A'); osascript -e \"display notification \\\"Stop. [$branch]\\\" with title \\\"Claude Code\\\" sound name \\\"Hero\\\"\""
          }
        ]
      }
    ]
  },
  "env": {
    "NIPPO_REPORTS_DIR": "reports"
  }
}
